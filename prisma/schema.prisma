// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "../node_modules/.prisma/client"
    previewFeatures = ["driverAdapters"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Multi-Tenant: Tabela de Distribuidoras (Tenants)
model tenant {
  id             String    @id @default(uuid())
  companyname    String    // Nome da empresa: "Distribuidora ABC Ltda"
  appname        String    // Nome no app: "ABC Gás"
  subdomain      String    @unique // "abc" → cliente acessa via código/subdomain
  customdomain   String?   // "app.distribuidoraabc.com.br" (opcional)
  logourl        String?   // URL do logo no S3
  splashscreenurl String?  // URL da splash screen no S3
  primarycolor   String    @default("#FF5722") // Cor primária hex
  secondarycolor String    @default("#2196F3") // Cor secundária hex
  email          String    // Email de contato da distribuidora
  phone          String?   // Telefone da distribuidora
  isactive       Boolean   @default(true) // Ativar/desativar distribuidora
  createdat      DateTime  @default(now())
  updatedat      DateTime  @updatedAt
  
  // Relações
  users          user[]
  products       product[]
  orders         order[]
  coupons        coupon[]

  @@index([subdomain])
}

model user {
  id        String    @id @default(uuid())
  tenantid  String?   // NULL apenas para superadmin
  tenant    tenant?   @relation(fields: [tenantid], references: [id], onDelete: Cascade)
  name      String
  email     String    
  password  String
  phone                       String?
  phoneverified               Boolean   @default(true)   // true por padrão para usuários existentes
  phoneverificationcode       String?
  phoneverificationexpiresat  DateTime?
  role      String    // 'superadmin', 'admin', 'client', 'entregador'
  pushtoken String?   // Expo Push Token
  lgpdacceptedat DateTime? // Data/hora do aceite dos termos LGPD
  passwordresetcode       String?   // Código de reset de senha
  passwordresetexpiresat  DateTime? // Expiração do código de reset
  available  Boolean  @default(false) // Entregador disponível para receber pedidos
  latitude   Float?   // Última localização GPS do entregador
  longitude  Float?   // Última localização GPS do entregador
  locationupdatedat DateTime? // Quando a localização foi atualizada pela última vez
  createdat DateTime  @default(now())
  addresses       address[]
  orders          order[]        @relation("UserOrders")
  deliveredorders order[]        @relation("DelivererOrders")
  couponusages    coupon_usage[]
  orderactivities order_activity[]

  @@unique([email, tenantid]) // Email pode repetir entre tenants, mas não dentro do mesmo tenant
  @@index([tenantid])
  @@index([email])
  @@index([available])
}

model address {
  id           String  @id @default(uuid())
  userid       String
  user         user    @relation(fields: [userid], references: [id], onDelete: Cascade)
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipcode      String
  isdefault    Boolean @default(false)
  orders       order[]
  
  @@index([userid])
}

model product {
  id          String      @id @default(uuid())
  tenantid    String      // CRÍTICO: Cada produto pertence a uma distribuidora
  tenant      tenant      @relation(fields: [tenantid], references: [id], onDelete: Cascade)
  name        String
  category    String      // 'Botijões', 'Água', 'Acessórios', 'Serviços'
  description String
  price       Float
  imageurl    String
  stock       Int         @default(0)
  createdat   DateTime    @default(now())
  orderitems  orderitem[]
  
  @@index([tenantid])
  @@index([category])
}

model order {
  id            String      @id @default(uuid())
  tenantid      String      // CRÍTICO: Cada pedido pertence a uma distribuidora
  tenant        tenant      @relation(fields: [tenantid], references: [id], onDelete: Cascade)
  userid        String
  user          user        @relation("UserOrders", fields: [userid], references: [id])
  delivererid   String?
  deliverer     user?       @relation("DelivererOrders", fields: [delivererid], references: [id])
  addressid     String
  address       address     @relation(fields: [addressid], references: [id])
  totalamount   Float
  paymentmethod String      // 'Dinheiro', 'Pix', 'Cartão'
  status        String      @default("Pendente") // 'Pendente', 'Em Preparo', 'Saiu para Entrega', 'Entregue', 'Cancelado'
  observations   String?
  cancelreason   String?
  couponcode     String?
  discountamount Float?
  cpfcnpj        String?
  changefor      Float?    // Troco: valor que o cliente vai pagar em dinheiro
  createdat      DateTime    @default(now())
  updatedat     DateTime       @updatedAt
  items         orderitem[]
  activities    order_activity[]
  
  @@index([tenantid])
  @@index([userid])
  @@index([status])
}

model orderitem {
  id        String  @id @default(uuid())
  orderid   String
  order     order   @relation(fields: [orderid], references: [id], onDelete: Cascade)
  productid String
  product   product @relation(fields: [productid], references: [id])
  quantity  Int
  unitprice Float
  subtotal  Float

  @@index([orderid])
  @@index([productid])
}

model coupon {
  id             String         @id @default(uuid())
  tenantid       String
  tenant         tenant         @relation(fields: [tenantid], references: [id], onDelete: Cascade)
  code           String
  discounttype   String         // 'percentage' | 'fixed'
  discountvalue  Float
  maxuses        Int?
  usedcount      Int            @default(0)
  isactive       Boolean        @default(true)
  expiresat      DateTime?
  createdat      DateTime       @default(now())
  usages         coupon_usage[]

  @@unique([code, tenantid])
  @@index([tenantid])
}

model order_activity {
  id        String   @id @default(uuid())
  orderid   String
  order     order    @relation(fields: [orderid], references: [id], onDelete: Cascade)
  userid    String?
  user      user?    @relation(fields: [userid], references: [id], onDelete: SetNull)
  type      String   // 'system' | 'message'
  content   String
  createdat DateTime @default(now())

  @@index([orderid])
}

model coupon_usage {
  id        String   @id @default(uuid())
  couponid  String
  coupon    coupon   @relation(fields: [couponid], references: [id], onDelete: Cascade)
  userid    String
  user      user     @relation(fields: [userid], references: [id], onDelete: Cascade)
  createdat DateTime @default(now())

  @@unique([couponid, userid])
  @@index([couponid])
  @@index([userid])
}
