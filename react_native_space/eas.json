{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "base": {
      "distribution": "store",
      "android": { "buildType": "apk" }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_TENANT_SUBDOMAIN": "demo",
        "EXPO_PUBLIC_API_URL": "http://localhost:3000"
      }
    },
    "demo": {
      "extends": "base",
      "channel": "demo",
      "env": {
        "EXPO_PUBLIC_TENANT_SUBDOMAIN": "demo",
        "EXPO_PUBLIC_API_URL": "https://api.seudominio.com.br"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
